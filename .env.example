# Copy to .env and fill in real values. The schema in src/config/index.ts
# validates these at startup — the app exits with a clear error if any
# required value is missing or malformed.

NODE_ENV=development
BASE_URL=0.0.0.0
PORT=8001

# MONGO_URL=mongodb+srv://<user>:<password>@<cluster>/<db>?retryWrites=true&w=majority
MONGO_URL=mongodb://localhost:27017/templateDB

BCRYPT_SALT_ROUNDS=12

# Generate secrets with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-a-random-string-of-at-least-32-characters
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace-with-a-different-random-string-of-at-least-32-chars
JWT_REFRESH_EXPIRES_IN=30d

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_MAIL=example@gmail.com
SMTP_PASSWORD=xxxxxxxxxx
SMTP_SERVICE=gmail
SERVICE_NAME=Mount Fuji

# Used once by: npm run seed:admin
SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASSWORD=change-me-immediately

STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxx

# variables
EMAIL_TEMP_IMAGE=https://example.com/logo.png
