  "item": [
    {
      "name": "System",
      "description": "Liveness and health probes. No authentication required.",
      "item": [
        {
          "name": "Welcome",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/",
              "host": ["{{baseUrl}}"],
              "path": [""]
            },
            "description": "Returns a welcome message. Useful as a liveness probe."
          },
          "response": []
        },
        {
          "name": "Health Check",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Service is healthy\", () => {",
                  "  pm.response.to.have.status(200);",
                  "  pm.expect(pm.response.json().db).to.eql(\"up\");",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": ["{{baseUrl}}"],
              "path": ["health"]
            },
            "description": "Reports DB connectivity and process uptime. Returns 503 when the database is unreachable."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Auth",
      "description": "Registration, OTP activation, login, token refresh, and password management.\n\nTokens are captured into collection variables automatically by the test scripts on Login, Activate Account, and Refresh Token.",
      "item": [
        {
          "name": "Register",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Jane Doe\",\n  \"email\": \"{{userEmail}}\",\n  \"role\": \"USER\",\n  \"password\": \"{{userPassword}}\",\n  \"confirmPassword\": \"{{userPassword}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "register"]
            },
            "description": "Creates an inactive USER account and emails a 6-digit activation code (3-minute expiry). Only role USER may self-register — ADMIN/SUPER_ADMIN are rejected with 400."
          },
          "response": []
        },
        {
          "name": "Activate Account",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json?.data?.accessToken) {",
                  "  pm.collectionVariables.set(\"accessToken\", json.data.accessToken);",
                  "  pm.collectionVariables.set(\"refreshToken\", json.data.refreshToken);",
                  "  console.log(\"Tokens saved to collection variables\");",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{userEmail}}\",\n  \"activationCode\": \"123456\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/activate-account",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "activate-account"]
            },
            "description": "Verifies the emailed OTP and activates the account. Replace 123456 with the real code. On success the returned tokens are stored automatically.\n\nRate limit: 5/15min. Codes are invalidated after 5 wrong attempts."
          },
          "response": []
        },
        {
          "name": "Resend Activation Code",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{userEmail}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/activation-code-resend",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "activation-code-resend"]
            },
            "description": "Re-issues the activation OTP and resets the attempt counter. Rate limit: 3/15min."
          },
          "response": []
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json?.data?.accessToken) {",
                  "  pm.collectionVariables.set(\"accessToken\", json.data.accessToken);",
                  "  pm.collectionVariables.set(\"refreshToken\", json.data.refreshToken);",
                  "  console.log(\"Tokens saved to collection variables\");",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{userEmail}}\",\n  \"password\": \"{{userPassword}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            },
            "description": "Authenticates and returns an access token (15 min) + refresh token (30 days). Tokens are stored automatically. Rate limit: 10/hour."
          },
          "response": []
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json?.data?.accessToken) {",
                  "  pm.collectionVariables.set(\"accessToken\", json.data.accessToken);",
                  "  console.log(\"Access token refreshed\");",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/refresh-token",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "refresh-token"]
            },
            "description": "Exchanges the refresh token for a fresh access token (also accepts the httpOnly cookie set at login). The new access token is stored automatically. Rate limit: 5/15min."
          },
          "response": []
        },
        {
          "name": "Forgot Password",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{userEmail}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/forgot-password",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "forgot-password"]
            },
            "description": "Emails a 6-digit password-reset code. Rate limit: 3/15min."
          },
          "response": []
        },
        {
          "name": "Verify Reset Code",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{userEmail}}\",\n  \"code\": \"123456\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/forget-pass-otp-verify",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "forget-pass-otp-verify"]
            },
            "description": "Verifies the reset OTP and unlocks Reset Password for this account. Rate limit: 5/15min."
          },
          "response": []
        },
        {
          "name": "Reset Password",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{userEmail}}\",\n  \"newPassword\": \"new-password-456\",\n  \"confirmPassword\": \"new-password-456\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/reset-password",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "reset-password"]
            },
            "description": "Sets a new password. Requires a successful Verify Reset Code call first (403 otherwise). Rate limit: 5/15min."
          },
          "response": []
        },
        {
          "name": "Change Password",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"oldPassword\": \"{{userPassword}}\",\n  \"newPassword\": \"new-password-456\",\n  \"confirmPassword\": \"new-password-456\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/change-password",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "change-password"]
            },
            "description": "Changes the authenticated account's password after verifying the old one. Uses the collection bearer token."
          },
          "response": []
        }
      ]
    },
