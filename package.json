{
  "name": "top-of-everest",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "memory-usage": "node --trace_gc src/server.js",
    "lint:check": "eslint --ignore-path .eslintignore --ext .js .",
    "lint:fix": "eslint . --fix",
    "prettier:fix": "prettier --write .",
    "prettier:check": "prettier --ignore-path .gitignore --check \"**/*.+(js|json)\"",
    "lint-prettier": "yarn lint:check && yarn prettier:check",
    "make:file": "node src/util/generateModule.js"
  },
  "lint-staged": {
    "src/**/*.js": "yarn lint-prettier"
  },
  "keywords": [],
  "author": "thakur-saad",
  "license": "ISC",
  "description": "top of everest",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "body-parser": "^2.2.2",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "ejs": "^5.0.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "http-status": "^2.1.0",
    "jsonwebtoken": "^9.0.3",
    "mongo": "^0.1.0",
    "mongodb": "^7.1.0",
    "mongoose": "^9.3.0",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.2",
    "socket.io": "^4.8.3",
    "stream": "^0.0.3",
    "stripe": "^20.4.1",
    "validator": "^13.15.26",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0"
  }
}
